# TerminalForge — Environment Variables Template
# Copy this file to .env and fill in your values
# NEVER commit .env to git

# ── LLM Provider ──────────────────────────────────────────────────────────
# Default provider when running plain "npm run ui" or "npm run go".
# You never need to edit this line to switch — use the npm scripts instead:
#   npm run ui:claude     → TUI with Anthropic Claude
#   npm run ui:ollama     → TUI with local Ollama (no internet, no cost)
#   npm run go:claude     → full stack with Anthropic
#   npm run go:ollama     → full stack with Ollama
# "anthropic" (default) — uses Claude API, requires ANTHROPIC_API_KEY below
# "ollama"              — uses local Ollama model, runs 100% offline
LLM_PROVIDER=anthropic

# Anthropic Claude API (required when LLM_PROVIDER=anthropic)
ANTHROPIC_API_KEY=sk-ant-...

# ── Ollama settings (only used when LLM_PROVIDER=ollama) ──────────────────
# Model to use — must be pulled first: ollama pull llama3.1:8b
# Good options by RAM:
#   4 GB  → llama3.2             (fast, weaker reasoning)
#   8 GB  → llama3.1:8b          (good balance)          ← default
#   8 GB  → qwen2.5-coder:7b     (better at code tasks)
#  16 GB  → qwen2.5-coder:14b    (strong code model)
#  32 GB  → llama3.1:32b         (very capable)
#  64 GB  → llama3.1:70b         (Claude-tier quality)
OLLAMA_MODEL=llama3.1:8b
OLLAMA_BASE_URL=http://localhost:11434

# ── Per-agent provider overrides (optional — mix Claude + Ollama) ──────────
# Override LLM_PROVIDER on a per-terminal basis.
# If not set, each agent inherits the global LLM_PROVIDER above.
#
# Example: Junior/QA/DevOps on local Ollama, Senior/PM on Claude:
#   AGENT_1_PROVIDER=ollama
#   AGENT_2_PROVIDER=anthropic
#   AGENT_3_PROVIDER=ollama
#   AGENT_4_PROVIDER=ollama
#   AGENT_5_PROVIDER=anthropic
#
# Agent map: 1=Junior Dev  2=Senior Dev  3=QA Engineer  4=DevOps  5=Project Manager
#AGENT_1_PROVIDER=ollama
#AGENT_2_PROVIDER=anthropic
#AGENT_3_PROVIDER=ollama
#AGENT_4_PROVIDER=ollama
#AGENT_5_PROVIDER=anthropic

# ── TTS / Voice output ────────────────────────────────────────────────────────
# Agent responses are spoken aloud by FORGE using macOS `say` by default.
# No setup needed — it works out of the box on macOS.
#
# To use ElevenLabs for a higher-quality voice, set your API key below
# and set TTS_PROVIDER=elevenlabs
TTS_PROVIDER=say          # "say" (macOS built-in) | "elevenlabs"
TTS_VOICE=Alex            # macOS: Alex, Samantha, Daniel, Tom, Fred  |  run: say -v ?
TTS_RATE=185              # words per minute (say only)
TTS_MAX_CHARS=420         # max chars spoken per response (truncates at sentence break)

# ElevenLabs TTS (optional — macOS say is used if not set)
ELEVENLABS_API_KEY=

# Bridge server port (default: 3333)
BRIDGE_PORT=3333

# Debug namespaces (comma-separated, or * for all)
# Namespaces: tf:core, tf:bridge, tf:agent, tf:voice, tf:ui
DEBUG=tf:*

# Voice mode: push-to-talk | wake-word | auto-vad
VOICE_MODE=push-to-talk
