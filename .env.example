# TerminalForge — Environment Variables Template
# Copy this file to .env and fill in your values
# NEVER commit .env to git

# Anthropic Claude API
ANTHROPIC_API_KEY=sk-ant-...

# ElevenLabs TTS (optional — macOS say is used if not set)
ELEVENLABS_API_KEY=

# Bridge server port (default: 3333)
BRIDGE_PORT=3333

# Debug namespaces (comma-separated, or * for all)
# Namespaces: tf:core, tf:bridge, tf:agent, tf:voice, tf:ui
DEBUG=tf:*

# Voice mode: push-to-talk | wake-word | auto-vad
VOICE_MODE=push-to-talk
