{
  "name": "terminalforge",
  "version": "1.0.0",
  "description": "macOS terminal-based multi-agent AI development platform",
  "type": "module",
  "engines": {
    "node": ">=18.0.0"
  },
  "scripts": {
    "start": "node bridge/server.js",
    "go": "bash scripts/start.sh",
    "go:claude": "LLM_PROVIDER=anthropic bash scripts/start.sh",
    "go:ollama": "LLM_PROVIDER=ollama bash scripts/start.sh",
    "go:voice": "bash scripts/start.sh --voice",
    "go:auto": "bash scripts/start.sh --voice=auto",
    "go:no-voice": "bash scripts/start.sh --no-voice",
    "go:debug": "bash scripts/start.sh --debug",
    "launch": "bash scripts/launch.sh",
    "launch:tmux": "bash scripts/tmux-layout.sh",
    "agent": "node scripts/agent-repl.js",
    "monitor": "node scripts/bus-monitor.js",
    "ui": "npx tsx scripts/ui.js",
    "ui:claude": "LLM_PROVIDER=anthropic npx tsx scripts/ui.js",
    "ui:ollama": "LLM_PROVIDER=ollama npx tsx scripts/ui.js",
    "ui:debug": "DEBUG=tf:* npx tsx scripts/ui.js",
    "ui:claude:debug": "LLM_PROVIDER=anthropic DEBUG=tf:* npx tsx scripts/ui.js",
    "ui:ollama:debug": "LLM_PROVIDER=ollama DEBUG=tf:* npx tsx scripts/ui.js",
    "voice": "python3 voice/pipeline.py",
    "voice:auto": "python3 voice/pipeline.py --mode auto-vad",
    "voice:wake": "python3 voice/pipeline.py --mode wake-word",
    "voice:debug": "python3 voice/pipeline.py --debug",
    "voice:hotkey": "node bridge/hotkey-fallback.js",
    "voice:tts": "python3 voice/tts.py",
    "test": "node --experimental-vm-modules node_modules/.bin/jest",
    "test:switch": "node tests/test-switch.js",
    "test:agents": "node tests/test-agents.js",
    "test:smoke": "node tests/smoke-test-agents.js",
    "lint": "eslint . --ext .js"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.39.0",
    "debug": "^4.3.4",
    "dotenv": "^16.4.5",
    "express": "^4.19.2",
    "ink": "^4.4.1",
    "ink-text-input": "^5.0.1",
    "openai": "^6.35.0",
    "react": "^18.3.1",
    "simple-git": "^3.25.0"
  },
  "devDependencies": {
    "eslint": "^9.0.0",
    "jest": "^29.7.0",
    "tsx": "^4.21.0"
  }
}
